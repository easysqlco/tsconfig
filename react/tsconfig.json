{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Package Development",
  "compilerOptions": {
    // Modern output for bundlers
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    // Consumer-owned rootDir/outDir stay local. This base only defines emit defaults.
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // JS-friendly strictness balance used across current EasySQL packages
    "allowJs": true,
    "noImplicitAny": false,
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,

    // Resolution rules
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,

    // Behavior
    "forceConsistentCasingInFileNames": true
  }
}
