{
  "name": "@easysqlco/tsconfig",
  "version": "0.0.5",
  "description": "Provides shared TypeScript base configs for EasySQL packages",
  "author": "EasySQL",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/easysqlco/tsconfig.git"
  },
  "homepage": "https://github.com/easysqlco/tsconfig#readme",
  "keywords": [
    "typescript",
    "tsconfig",
    "react",
    "easysqlco",
    "shared-config"
  ],
  "files": [
    "dev/",
    "react/",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    "./dev": "./dev/tsconfig.json",
    "./react": "./react/tsconfig.json",
    "./react/build": "./react/tsconfig.build.json"
  },
  "scripts": {
    "validate": "node ./scripts/validate-package.mjs",
    "prepack": "npm run validate"
  },
  "peerDependencies": {
    "typescript": ">= 5 < 6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
